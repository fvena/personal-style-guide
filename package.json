{
  "name": "@franvena/kata",
  "version": "3.0.0",
  "description": "Code quality toolkit for Node.js and TypeScript. ESLint, Prettier, Stylelint, Markdownlint, and TypeScript configs — configured, enforced, maintained.",
  "keywords": [
    "a11y",
    "accessibility",
    "code-quality",
    "commitlint",
    "eslint",
    "eslint-config",
    "flat-config",
    "formatting",
    "husky",
    "lint-staged",
    "linting",
    "markdownlint",
    "nuxt",
    "nuxt3",
    "opinionated",
    "prettier",
    "quality",
    "scss",
    "shared-config",
    "style-guide",
    "stylelint",
    "tsconfig",
    "type-aware",
    "typescript",
    "vue",
    "vue3"
  ],
  "homepage": "https://github.com/fvena/kata#readme",
  "bugs": {
    "url": "https://github.com/fvena/kata/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fvena/kata.git"
  },
  "license": "MIT",
  "author": "Francisco Vena <fvena32@gmail.com> (https://www.fvena.com)",
  "type": "module",
  "exports": {
    "./eslint/base": "./eslint/base.js",
    "./eslint/browser": "./eslint/browser.js",
    "./eslint/node": "./eslint/node.js",
    "./eslint/vue": "./eslint/vue.js",
    "./eslint/nuxt": "./eslint/nuxt.js",
    "./eslint/playwright": "./eslint/playwright.js",
    "./eslint/testing-library": "./eslint/testing-library.js",
    "./eslint/turbo": "./eslint/turbo.js",
    "./eslint/vitest": "./eslint/vitest.js",
    "./prettier": "./prettier/index.js",
    "./stylelint": "./stylelint/index.js",
    "./typescript/node": "./typescript/tsconfig.node.json",
    "./typescript/browser": "./typescript/tsconfig.browser.json",
    "./markdown": "./markdown/markdownlint.json"
  },
  "bin": {
    "kata": "./cli/index.js"
  },
  "files": [
    "eslint",
    "prettier",
    "stylelint",
    "typescript",
    "markdown",
    "cli"
  ],
  "scripts": {
    "attw": "attw --pack .",
    "benchmark": "bash scripts/benchmark.sh",
    "format": "prettier --write .",
    "knip": "knip",
    "lint": "eslint .",
    "prepare": "husky",
    "publint": "publint",
    "release": "release-it --only-version",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "!(examples/**)*": "prettier -w --ignore-unknown",
    "!(examples/**)*.{js,ts}": "eslint --fix"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^7.5.1",
    "@nuxt/eslint-config": "^1.15.2",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-oxlint": "^1.56.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "eslint-plugin-yml": "^3.3.1",
    "globals": "^17.4.0",
    "postcss-html": "^1.8.1",
    "prettier-plugin-packagejson": "^3.0.0",
    "stylelint-config-recess-order": "^7.6.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript-eslint": "^8.56.1"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/node": "^25.5.0",
    "@vitest/eslint-plugin": "^1.0.0",
    "eslint": "^10.0.0",
    "eslint-config-turbo": "^2.8.13",
    "eslint-plugin-playwright": "^2.9.0",
    "eslint-plugin-testing-library": "^7.16.0",
    "husky": "^9.1.7",
    "knip": "^6.0.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "publint": "^0.3.0",
    "release-it": "^19.2.4",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@vitest/eslint-plugin": "^1.0.0",
    "eslint": "^10.0.0",
    "eslint-config-turbo": "^2.8.13",
    "eslint-plugin-playwright": "^2.9.0",
    "eslint-plugin-testing-library": "^7.16.0",
    "oxlint": "^1.0.0",
    "prettier": "^3.0.0",
    "stylelint": "^17.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependenciesMeta": {
    "@vitest/eslint-plugin": {
      "optional": true
    },
    "eslint-config-turbo": {
      "optional": true
    },
    "eslint-plugin-playwright": {
      "optional": true
    },
    "eslint-plugin-testing-library": {
      "optional": true
    },
    "oxlint": {
      "optional": true
    },
    "prettier": {
      "optional": true
    },
    "stylelint": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
