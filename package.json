{
  "name": "@fvena/style-guide",
  "version": "0.7.0",
  "description": "Zero-config, opinionated linting and formatting for TypeScript, Vue, and Nuxt projects.",
  "keywords": [
    "eslint",
    "eslint-config",
    "flat-config",
    "prettier",
    "stylelint",
    "typescript",
    "tsconfig",
    "style-guide",
    "shared-config",
    "linting",
    "formatting",
    "vue",
    "nuxt",
    "code-quality"
  ],
  "homepage": "https://github.com/fvena/style-guide#readme",
  "bugs": {
    "url": "https://github.com/fvena/style-guide/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fvena/style-guide.git"
  },
  "license": "MIT",
  "author": "Francisco Vena <fvena32@gmail.com> (https://www.fvena.com)",
  "type": "module",
  "exports": {
    "./eslint/base": "./eslint/base.js",
    "./eslint/browser": "./eslint/browser.js",
    "./eslint/node": "./eslint/node.js",
    "./eslint/vue": "./eslint/vue.js",
    "./eslint/nuxt": "./eslint/nuxt.js",
    "./eslint/playwright": "./eslint/playwright.js",
    "./eslint/testing-library": "./eslint/testing-library.js",
    "./eslint/turbo": "./eslint/turbo.js",
    "./prettier": "./prettier/index.js",
    "./stylelint": "./stylelint/index.js",
    "./typescript/node": "./typescript/tsconfig.node.json",
    "./typescript/browser": "./typescript/tsconfig.browser.json",
    "./markdown": "./markdown/markdownlint.json"
  },
  "files": [
    "eslint",
    "prettier",
    "stylelint",
    "typescript",
    "markdown"
  ],
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint .",
    "prepare": "husky",
    "release": "release-it --only-version",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*": "prettier -w --ignore-unknown",
    "*.{js,ts}": "eslint --fix"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^9.39.3",
    "@eslint/markdown": "^7.5.1",
    "@nuxt/eslint-config": "^1.15.2",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-turbo": "^2.8.13",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-playwright": "^2.9.0",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-testing-library": "^7.16.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "eslint-plugin-yml": "^3.3.1",
    "globals": "^17.4.0",
    "prettier-plugin-packagejson": "^3.0.0",
    "stylelint-config-recess-order": "^7.6.1",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-order": "^7.0.1",
    "typescript-eslint": "^8.56.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@release-it/conventional-changelog": "^10.0.5",
    "eslint": "^9.39.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "stylelint": "^17.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "prettier": {
      "optional": true
    },
    "stylelint": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.11.0"
  }
}
