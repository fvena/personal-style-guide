{
  "name": "personal-style-guide",
  "version": "0.6.0",
  "description": "A shared configuration for ESLint, Markdownlint, Prettier, and Stylelint to ensure consistent and clean code across your projects.",
  "keywords": [
    "ESLint",
    "Markdownlint",
    "Prettier",
    "Stylelint",
    "Vitest",
    "Typescript",
    "Vue 3",
    "Nuxt 4",
    "Style",
    "Guide",
    "Accessibility",
    "Testing",
    "JSON",
    "Markdown"
  ],
  "homepage": "https://github.com/fvena/personal-style-guide#readme",
  "bugs": {
    "url": "https://github.com/fvena/personal-style-guide/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fvena/personal-style-guide.git"
  },
  "license": "MIT",
  "author": "Francisco Vena <fvena32@gmail.com> (https://www.fvena.com)",
  "type": "module",
  "exports": {
    "./eslint/*": "./eslint/*.js",
    "./markdownlint/*": "./markdownlint/*.jsonc",
    "./prettier/*": "./prettier/*.js",
    "./stylelint/*": "./stylelint/*.js",
    "./typescript/browser": "./typescript/tsconfig.browser.json",
    "./typescript/node": "./typescript/tsconfig.node.json",
    "./vitest/*": "./vitest/*.js",
    "./vitest/setup/*": "./vitest/setup/*.js"
  },
  "files": [
    "eslint",
    "markdownlint",
    "prettier",
    "stylelint",
    "vitest",
    "typescript"
  ],
  "scripts": {
    "audit:deps": "npm audit --audit-level=moderate",
    "check:deps": "npx npm-check-updates  --interactive --format group",
    "format": "prettier --write .",
    "lint": "npm run lint:js && npm run lint:md",
    "lint:js": "eslint .",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules'",
    "lint:md:fix": "markdownlint-cli2 --fix '**/*.md' '#node_modules'",
    "prepare": "husky",
    "release": "release-it --only-version",
    "test": "echo \"Error: no test specified\" && exit 1",
    "typecheck": "tsc --noEmit",
    "validate:configs": "node scripts/validate-configs.js"
  },
  "lint-staged": {
    "*": "prettier -w --ignore-unknown"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.5.0",
    "@eslint/js": "^9.34.0",
    "@eslint/json": "^0.6.0",
    "@nuxt/eslint": "^0.7.2",
    "@prettier/plugin-pug": "^3.4.2",
    "@typescript-eslint/parser": "^8.41.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.21.3",
    "eslint-plugin-package-json": "^0.56.0",
    "eslint-plugin-perfectionist": "^4.15.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-tsdoc": "^0.4.0",
    "eslint-plugin-unicorn": "^60.0.0",
    "eslint-plugin-vitest": "^0.5.4",
    "eslint-plugin-vue": "^9.32.0",
    "eslint-plugin-vuejs-accessibility": "^2.4.1",
    "eslint-plugin-yml": "^1.18.0",
    "globals": "^16.3.0",
    "jsdom": "^26.0.0",
    "prettier-plugin-packagejson": "^2.5.19",
    "stylelint-config-recess-order": "^7.2.0",
    "stylelint-config-recommended": "^17.0.0",
    "stylelint-config-recommended-scss": "^16.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "typescript-eslint": "^8.41.0",
    "vue-eslint-parser": "^9.4.3",
    "yaml-eslint-parser": "^1.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@release-it/conventional-changelog": "^10.0.1",
    "eslint": "^9.34.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.6.2",
    "release-it": "^19.0.4"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "markdownlint": "^0.35.0",
    "markdownlint-cli2": "^0.15.0",
    "nuxt": "^3.0.0",
    "prettier": "^3.0.0",
    "stylelint": "^16.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    },
    "markdownlint": {
      "optional": true
    },
    "markdownlint-cli2": {
      "optional": true
    },
    "nuxt": {
      "optional": true
    },
    "prettier": {
      "optional": true
    },
    "stylelint": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "vitest": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.11.0"
  }
}
